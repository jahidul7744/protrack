# App
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Neon PostgreSQL (Prisma)
# Use the pooled Neon URL for production/serverless.
DATABASE_URL="postgresql://<user>:<password>@<host>/<database>?sslmode=require&pgbouncer=true&connect_timeout=15"

# NextAuth
# Local example:
# NEXTAUTH_URL="http://localhost:3000"
# Production example:
# NEXTAUTH_URL="https://your-vercel-domain.vercel.app"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# OAuth (optional, needed if Google login is enabled)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini AI
GEMINI_API_KEY="MY_GEMINI_API_KEY"
# If client-side usage is required in your app:
# NEXT_PUBLIC_GEMINI_API_KEY="MY_GEMINI_API_KEY"
